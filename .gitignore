# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# MCP config (contains tokens)
.mcp.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# credentials / sensitive docs
DB_info.md

# uploaded user data
/upload-data/

# database dumps
*.dump

# syncthing conflict files
*.sync-conflict-*

# claude session files
.claude/
memory/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
