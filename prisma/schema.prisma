generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "pgntarg2udzj1f3"]
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String
  role          String   @default("member")
  bearer_token  String?  @unique @db.VarChar(64)
  position      String?
  contact_phone String?
  faa_part_107  Boolean  @default(false)
  status        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ProjectLabMembers  ProjectLabMember[]
  LabMemberUploads   LabMemberUpload[]
  TaskAssignees      TaskAssignee[]
  ProjectFilters     UserProjectFilter[]
  FarmFilters        UserFarmFilter[]
  FilterSettings     UserFilterSettings?
  CreatedExperiments FarmExperiment[]    @relation("ExperimentCreatedBy")

  @@map("users")
  @@schema("public")
}

model UserProjectFilter {
  user_id    String
  project_id Int
  User       User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, project_id])
  @@map("User_Project_Filters")
  @@schema("public")
}

model UserFarmFilter {
  user_id String
  farm_id Int
  User    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, farm_id])
  @@map("User_Farm_Filters")
  @@schema("public")
}

model UserFilterSettings {
  user_id         String  @id
  show_unassigned Boolean @default(true)
  User            User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("User_Filter_Settings")
  @@schema("public")
}

model SiteConfig {
  key   String @id
  value String @default("false")

  @@map("site_config")
  @@schema("public")
}

model Project {
  id               Int       @id @default(autoincrement())
  title            String?
  Project_Name     String?
  Project_Sponsors String?
  Total_Budget     Decimal?
  Year_Started     Int?
  Status           String?
  created_at       DateTime?
  updated_at       DateTime?

  TreatmentProtocols     TreatmentProtocol[]
  ExperimentZones        ExperimentZone[]
  ProjectFarms           ProjectFarm[]
  ProjectLabMembers      ProjectLabMember[]
  FarmExperiments        FarmExperiment[]
  Photos                 Photo[]
  Notes                  Note[]
  Recordings             Recording[]
  Locations              Location[]
  Videos                 Video[]
  Documents              Document[]
  LabMemberUploads       LabMemberUpload[]
  ReportingSubscriptions ReportingSubscription[]
  CvatTasks              CvatTask[]

  @@map("Projects")
  @@schema("pgntarg2udzj1f3")
}

model Farm {
  id            Int       @id @default(autoincrement())
  title         String?
  Farm_Name     String?
  County        String?
  State         String?
  is_active     Boolean   @default(true)
  created_at    DateTime? @default(now())
  updated_at    DateTime? @updatedAt

  farm_summary    String?
  address         String?
  latitude        Float?
  longitude       Float?

  Fields           Field[]
  ExperimentZones  ExperimentZone[]
  ProjectFarms     ProjectFarm[]
  Contacts         Contact[]
  Photos           Photo[]
  Notes            Note[]
  Recordings       Recording[]
  Locations        Location[]
  Videos           Video[]
  Documents        Document[]
  ContactCards     WhatsAppContactCard[]
  LabMemberUploads LabMemberUpload[]
  FarmExperiments  FarmExperiment[]

  @@map("Farms")
  @@schema("pgntarg2udzj1f3")
}


model Field {
  id              Int       @id @default(autoincrement())
  Name            String?
  geometry        String?
  boundary_source String?
  Farms_id        Int?
  created_at      DateTime?
  updated_at      DateTime?

  Farm            Farm?            @relation(fields: [Farms_id], references: [id])
  FieldTests      FieldTest[]
  FieldCrops      FieldCrop[]
  FieldDrones     FieldDrone[]
  DualexReadings  Dualex[]
  ExperimentZones ExperimentZone[]
  ExperimentFields ExperimentField[]

  @@map("Fields")
  @@schema("pgntarg2udzj1f3")
}

model Dualex {
  id             Int       @id @default(autoincrement())
  title          String?   @map("Title")
  instrumentId   Int?      @map("Instrument ID")
  temperature    Decimal?  @map("Temperature")
  chlorophyll    Decimal?  @map("Chlorophyll")
  flavonoids     Decimal?  @map("Flavonoids")
  anth           Decimal?  @map("Anth")
  nbi            Decimal?  @map("NBI")
  collectionDate DateTime? @map("Collection Date") @db.Date
  collectionTime DateTime? @map("Collection Time") @db.Time(6)
  location       String?   @map("Location")
  fieldsId       Int?      @map("Fields_id")

  Field Field? @relation(fields: [fieldsId], references: [id])

  @@map("Dualex")
  @@schema("pgntarg2udzj1f3")
}

model Treatment {
  id               Int       @id @default(autoincrement())
  title            String?
  Treatment_Name   String?
  Description      String?
  Notes            String?
  allow_extra_rows Boolean   @default(false)
  created_at       DateTime?
  updated_at       DateTime?

  TreatmentProtocols        TreatmentProtocol[]
  ExperimentTreatments      ExperimentTreatment[]
  TreatmentFieldDefinitions TreatmentFieldDefinition[]

  @@map("Treatments")
  @@schema("pgntarg2udzj1f3")
}

model TreatmentProtocol {
  id            Int       @id @default(autoincrement())
  title         String?
  project_id    Int?
  treatment_id  Int?
  Protocol_Name String?
  Product       String?
  Rate          Decimal?
  Rate_Unit     String?
  Timing        String?
  Is_Control    Boolean?
  Notes         String?
  created_at    DateTime?
  updated_at    DateTime?

  Project         Project?   @relation(fields: [project_id], references: [id])
  Treatment       Treatment? @relation(fields: [treatment_id], references: [id])
  ExperimentZones ExperimentZone[]

  @@map("Treatment_Protocol")
  @@schema("pgntarg2udzj1f3")
}

model ExperimentZone {
  id              Int       @id @default(autoincrement())
  title           String?
  project_id      Int?
  farm_id         Int?
  Fields_id       Int?
  protocol_id     Int?
  geometry        String?
  Zone_Label      String?
  Rep_Number      Int?
  Boundary_Source String?
  created_at      DateTime?
  updated_at      DateTime?

  Project  Project?           @relation(fields: [project_id], references: [id])
  Farm     Farm?              @relation(fields: [farm_id], references: [id])
  Field    Field?             @relation(fields: [Fields_id], references: [id])
  Protocol TreatmentProtocol? @relation(fields: [protocol_id], references: [id])

  @@map("Experiment_Zones")
  @@schema("pgntarg2udzj1f3")
}

model Test {
  id                           Int       @id @default(autoincrement())
  title                        String?
  Test_Name                    String?
  Test_Description             String?
  Cost                         Decimal?
  Planned_Date                 DateTime?
  Completed_Date               DateTime?
  Methodology                  String?
  Data_Processing_Instructions String?
  created_at                   DateTime?
  updated_at                   DateTime?

  FieldTests           FieldTest[]
  ExperimentTests      ExperimentTest[]
  TestFieldDefinitions TestFieldDefinition[]
  TaskTemplates        TaskTemplate[]

  @@map("Tests")
  @@schema("pgntarg2udzj1f3")
}

model Drone {
  id                Int       @id @default(autoincrement())
  title             String?
  Name              String?
  Description       String?
  Cost_Per_Acre     Decimal?
  Mobilization_Cost Decimal?
  created_at        DateTime?
  updated_at        DateTime?

  FieldDrones            FieldDrone[]
  ExperimentDroneFlights ExperimentDroneFlight[]
  TaskTemplates          TaskTemplate[]

  @@map("Drones")
  @@schema("pgntarg2udzj1f3")
}

model Crop {
  id         Int       @id @default(autoincrement())
  title      String?
  Crop_Name  String?
  Crop_Type  String?
  created_at DateTime?
  updated_at DateTime?

  FieldCrops FieldCrop[]

  @@map("Crops")
  @@schema("pgntarg2udzj1f3")
}

// M2M join tables — column names match actual DB schema
model ProjectFarm {
  Projects_id Int
  Farms_id    Int
  Project     Project @relation(fields: [Projects_id], references: [id])
  Farm        Farm    @relation(fields: [Farms_id], references: [id])

  @@id([Farms_id, Projects_id])
  @@map("_nc_m2m_Projects_Farms")
  @@schema("pgntarg2udzj1f3")
}

model ProjectLabMember {
  Projects_id Int
  user_id     String
  Project     Project @relation(fields: [Projects_id], references: [id])
  User        User    @relation(fields: [user_id], references: [id])

  @@id([user_id, Projects_id])
  @@map("_nc_m2m_Projects_Lab Members")
  @@schema("pgntarg2udzj1f3")
}

model FieldTest {
  Fields_id Int
  Tests_id  Int
  Field     Field @relation(fields: [Fields_id], references: [id])
  Test      Test  @relation(fields: [Tests_id], references: [id])

  @@id([Tests_id, Fields_id])
  @@map("_nc_m2m_Fields_Tests")
  @@schema("pgntarg2udzj1f3")
}

model FieldCrop {
  Fields_id Int
  Crops_id  Int
  Field     Field @relation(fields: [Fields_id], references: [id])
  Crop      Crop  @relation(fields: [Crops_id], references: [id])

  @@id([Crops_id, Fields_id])
  @@map("_nc_m2m_Fields_Crops")
  @@schema("pgntarg2udzj1f3")
}

model FieldDrone {
  Fields_id  Int
  Drones_id  Int
  Field      Field @relation(fields: [Fields_id], references: [id])
  Drone      Drone @relation(fields: [Drones_id], references: [id])

  @@id([Drones_id, Fields_id])
  @@map("_nc_m2m_Fields_Drones")
  @@schema("pgntarg2udzj1f3")
}

model Contact {
  id            Int       @id @default(autoincrement())
  name          String
  email         String?
  phone         String?
  whatsapp      Boolean   @default(false)
  token         String    @default("")
  farms_id      Int?
  is_lab_member Boolean   @default(false)
  assigned_experiment_id Int?
  experiment_nickname    String?
  channel                String?   // "whatsapp" | "sms" | null — farmer's preferred messaging channel
  onboarded_at  DateTime?
  created_at    DateTime  @default(now())

  Farm               Farm?           @relation(fields: [farms_id], references: [id])
  AssignedExperiment FarmExperiment? @relation(fields: [assigned_experiment_id], references: [id], onDelete: SetNull)
  Photos     Photo[]
  Recordings Recording[]
  Notes      Note[]
  Locations  Location[]
  Videos     Video[]
  Documents  Document[]
  ContactCards WhatsAppContactCard[]

  @@map("Contacts")
  @@schema("pgntarg2udzj1f3")
}

model Photo {
  id          Int       @id @default(autoincrement())
  contact_id  Int?
  farm_id     Int?
  field_id    Int?
  project_id  Int?
  filename    String
  latitude    Float?
  longitude   Float?
  note        String?
  timestamp   DateTime?
  status      Int       @default(2)
  ticket_ref  String?                         // human-readable OFEDashBot reference
  category    String?   @db.VarChar(100)
  description String?
  stage          String?   @db.VarChar(50)
  merge_group_id String?   @db.VarChar(36)
  depth_filename String?
  received_at    DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Photos")
  @@schema("pgntarg2udzj1f3")
}

model Recording {
  id           Int       @id @default(autoincrement())
  contact_id   Int?
  farm_id      Int?
  field_id     Int?
  project_id   Int?
  filename     String
  gps_filename String?
  start_time   DateTime?
  end_time     DateTime?
  status       Int       @default(2)
  ticket_ref   String?                         // human-readable OFEDashBot reference
  category     String?   @db.VarChar(100)
  description  String?
  stage          String?   @db.VarChar(50)
  merge_group_id String?   @db.VarChar(36)
  received_at    DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Recordings")
  @@schema("pgntarg2udzj1f3")
}

model Note {
  id          Int       @id @default(autoincrement())
  contact_id  Int?
  farm_id     Int?
  field_id    Int?
  project_id  Int?
  content     String
  latitude    Float?
  longitude   Float?
  timestamp   DateTime?
  status      Int       @default(2)
  ticket_ref  String?                         // human-readable OFEDashBot reference
  category    String?   @db.VarChar(100)
  description String?
  stage          String?   @db.VarChar(50)
  merge_group_id String?   @db.VarChar(36)
  received_at    DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Notes")
  @@schema("pgntarg2udzj1f3")
}

model Location {
  id             Int       @id @default(autoincrement())
  contact_id     Int?
  farm_id        Int?
  field_id       Int?
  project_id     Int?
  name           String?
  track_filename String?
  start_time     DateTime?
  end_time       DateTime?
  status         Int       @default(2)
  ticket_ref     String?                         // human-readable OFEDashBot reference
  category       String?   @db.VarChar(100)
  description    String?
  stage          String?   @db.VarChar(50)
  merge_group_id String?   @db.VarChar(36)
  received_at    DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Locations")
  @@schema("pgntarg2udzj1f3")
}

model LabMemberUpload {
  id             Int       @id @default(autoincrement())
  lab_member_id  String?
  farm_id        Int?
  field_id       Int?
  project_id     Int?
  media_type     String    @db.VarChar(20)
  filename       String?
  content        String?
  latitude       Float?
  longitude      Float?
  gps_filename   String?
  start_time     DateTime?
  end_time       DateTime?
  date_collected DateTime?
  status         Int       @default(1)
  category       String?   @db.VarChar(100)
  description    String?
  stage          String?   @db.VarChar(50)
  merge_group_id String?   @db.VarChar(36)
  depth_filename String?
  received_at    DateTime  @default(now())

  User    User?    @relation(fields: [lab_member_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Lab_Member_Uploads")
  @@schema("pgntarg2udzj1f3")
}

model FarmExperiment {
  id               Int       @id @default(autoincrement())
  farm_id          Int?
  project_id       Int?
  experiment_name  String?
  start_date       DateTime? @db.Date
  end_date         DateTime? @db.Date
  hypothesis       String?
  experiment_desc  String?
  measurements     String?
  criteria         String?
  lab_description  String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  created_by_id    String?

  vikunja_project_id     Int?

  Farm                   Farm?                   @relation(fields: [farm_id], references: [id])
  Project                Project?                @relation(fields: [project_id], references: [id])
  CreatedBy              User?                   @relation("ExperimentCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  ExperimentTests        ExperimentTest[]
  ExperimentDroneFlights ExperimentDroneFlight[]
  ExperimentTreatments   ExperimentTreatment[]
  ExperimentFields       ExperimentField[]
  Tasks                  Task[]
  AssignedContacts       Contact[]

  @@map("Farm_Experiments")
  @@schema("pgntarg2udzj1f3")
}

model ExperimentTest {
  id            Int       @id @default(autoincrement())
  experiment_id Int
  test_id       Int
  n_samples     Int?
  expected_date DateTime? @db.Date
  status        String?

  Experiment FarmExperiment @relation(fields: [experiment_id], references: [id], onDelete: Cascade)
  Test       Test           @relation(fields: [test_id], references: [id], onDelete: Cascade)

  @@map("Experiment_Tests")
  @@schema("pgntarg2udzj1f3")
}

model ExperimentDroneFlight {
  id            Int       @id @default(autoincrement())
  experiment_id Int
  drone_id      Int
  n_flights     Int?
  expected_date DateTime? @db.Date
  status        String?

  Experiment         FarmExperiment      @relation(fields: [experiment_id], references: [id], onDelete: Cascade)
  Drone              Drone               @relation(fields: [drone_id], references: [id], onDelete: Cascade)
  DroneFlightRecords DroneFlightRecord[]

  @@map("Experiment_Drone_Flights")
  @@schema("pgntarg2udzj1f3")
}

model ExperimentTreatment {
  experiment_id            Int
  treatment_id             Int
  is_continuous            Boolean? @default(true)
  rate                     Decimal? @db.Decimal(10, 4)
  rate_unit                String?
  has_control_treatment    Boolean  @default(false)
  control_treatment_type   String?
  control_treatment_number Int?

  Experiment FarmExperiment @relation(fields: [experiment_id], references: [id], onDelete: Cascade)
  Treatment  Treatment      @relation(fields: [treatment_id], references: [id], onDelete: Cascade)

  @@id([experiment_id, treatment_id])
  @@map("Experiment_Treatments")
  @@schema("pgntarg2udzj1f3")
}

model ExperimentField {
  experiment_id Int
  field_id      Int

  Experiment FarmExperiment @relation(fields: [experiment_id], references: [id], onDelete: Cascade)
  Field      Field          @relation(fields: [field_id], references: [id], onDelete: Cascade)

  @@id([experiment_id, field_id])
  @@map("Experiment_Fields")
  @@schema("pgntarg2udzj1f3")
}

model TestFieldDefinition {
  id         Int    @id @default(autoincrement())
  test_id    Int
  col_index  Int
  field_type String @default("text")
  label      String

  Test Test @relation(fields: [test_id], references: [id], onDelete: Cascade)

  @@unique([test_id, col_index])
  @@map("Test_Field_Definitions")
  @@schema("pgntarg2udzj1f3")
}

model TreatmentFieldDefinition {
  id           Int    @id @default(autoincrement())
  treatment_id Int
  col_index    Int
  field_type   String @default("text")
  label        String

  Treatment Treatment                  @relation(fields: [treatment_id], references: [id], onDelete: Cascade)
  Values    ExperimentTreatmentValue[]

  @@unique([treatment_id, col_index])
  @@map("Treatment_Field_Definitions")
  @@schema("pgntarg2udzj1f3")
}

model ExperimentTreatmentValue {
  id            Int     @id @default(autoincrement())
  experiment_id Int
  treatment_id  Int
  field_def_id  Int
  row_index     Int
  value         String?

  FieldDef TreatmentFieldDefinition @relation(fields: [field_def_id], references: [id], onDelete: Cascade)

  @@unique([experiment_id, treatment_id, field_def_id, row_index])
  @@map("Experiment_Treatment_Values")
  @@schema("pgntarg2udzj1f3")
}

model Video {
  id          Int       @id @default(autoincrement())
  contact_id  Int?
  farm_id     Int?
  project_id  Int?
  filename    String
  latitude    Float?
  longitude   Float?
  note        String?
  timestamp   DateTime?
  status      Int       @default(2)
  ticket_ref  String?                         // human-readable OFEDashBot reference
  category    String?   @db.VarChar(100)
  description String?
  received_at DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Videos")
  @@schema("pgntarg2udzj1f3")
}

// Unified table: serves both dashboard farm/project file attachments
// (source = "dashboard") and inbound WhatsApp documents (source = "whatsapp").
model Document {
  id            Int       @id @default(autoincrement())
  source        String    @default("dashboard")  // dashboard | whatsapp
  contact_id    Int?
  farm_id       Int?
  project_id    Int?
  filename      String
  original_name String?                           // dashboard uploads
  file_type     String?   @db.VarChar(20)         // dashboard uploads
  file_size     Int?                              // dashboard uploads
  note          String?                           // whatsapp captions
  category      String?   @db.VarChar(100)
  description   String?
  timestamp     DateTime?                          // whatsapp message time
  status        Int       @default(2)
  ticket_ref    String?                            // human-readable OFEDashBot reference
  uploaded_at   DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])
  Project Project? @relation(fields: [project_id], references: [id])

  @@map("Documents")
  @@schema("pgntarg2udzj1f3")
}

model WhatsAppContactCard {
  id          Int       @id @default(autoincrement())
  contact_id  Int?
  farm_id     Int?
  shared_name  String
  shared_phone String?
  shared_email String?
  shared_org   String?
  note        String?
  status      Int       @default(2)
  ticket_ref  String?                         // human-readable OFEDashBot reference
  received_at DateTime  @default(now())

  Contact Contact? @relation(fields: [contact_id], references: [id])
  Farm    Farm?    @relation(fields: [farm_id], references: [id])

  @@map("WhatsApp_Contact_Cards")
  @@schema("pgntarg2udzj1f3")
}

model ReportingSubscription {
  id           Int       @id @default(autoincrement())
  project_id   Int?
  emails       String                          // semicolon-separated list
  frequency    String    @default("weekly")    // weekly | biweekly | monthly
  active       Boolean   @default(true)
  contact_ids  String?                         // legacy; contacts now derived from project at send time
  last_sent_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  Project      Project?  @relation(fields: [project_id], references: [id])

  @@map("Reporting_Subscriptions")
  @@schema("pgntarg2udzj1f3")
}

model DroneFlightRecord {
  id                         Int       @id @default(autoincrement())
  experiment_drone_flight_id Int
  flight_date                DateTime? @db.Date
  pilot                      String?
  flight_status              String?   @default("Scheduled")
  total_acres                Decimal?  @db.Decimal(10, 2)
  total_images               Int?
  needs_3d                   Boolean   @default(false)
  needs_ortho                Boolean   @default(false)
  processed                  Boolean   @default(false)
  data_storage_path          String?
  tile_coverage_pct          Decimal?  @db.Decimal(5, 2)
  tile_size_m                Decimal?  @db.Decimal(8, 2)
  notes                      String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  ExperimentDroneFlight ExperimentDroneFlight @relation(fields: [experiment_drone_flight_id], references: [id], onDelete: Cascade)
  Polygons              DroneFlightPolygon[]

  @@map("Drone_Flight_Records")
  @@schema("pgntarg2udzj1f3")
}

model DroneFlightPolygon {
  id               Int      @id @default(autoincrement())
  flight_record_id Int
  label            String?
  polygon_type     String?
  geometry         String?
  confidence       Decimal? @db.Decimal(5, 4)
  source           String?
  created_at       DateTime @default(now())

  FlightRecord DroneFlightRecord @relation(fields: [flight_record_id], references: [id], onDelete: Cascade)

  @@map("Drone_Flight_Polygons")
  @@schema("pgntarg2udzj1f3")
}

model CvatTask {
  id              Int      @id @default(autoincrement())
  project_id      Int?
  fdl_task_id     Int?
  cvat_task_id    Int?
  cvat_project_id Int?
  name            String
  label_set       Json     @default("[]")
  status          String   @default("pending")
  image_count     Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  Project     Project?     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  FdlTask     Task?        @relation(fields: [fdl_task_id], references: [id], onDelete: SetNull)
  Annotations Annotation[]

  @@map("Cvat_Tasks")
  @@schema("pgntarg2udzj1f3")
}

model MessageTemplate {
  id         Int      @id @default(autoincrement())
  name       String
  content    String
  created_at DateTime @default(now())

  @@map("MessageTemplates")
  @@schema("pgntarg2udzj1f3")
}

model Annotation {
  id           Int      @id @default(autoincrement())
  upload_id    Int
  upload_table String
  filename     String?
  cvat_task_id Int?
  shapes       Json     @default("[]")
  label_set    String[]
  annotated_by String?
  source       String   @default("cvat")
  created_at   DateTime @default(now())

  CvatTask CvatTask? @relation(fields: [cvat_task_id], references: [id], onDelete: SetNull)

  @@map("Annotations")
  @@schema("pgntarg2udzj1f3")
}

model Task {
  id               Int       @id @default(autoincrement())
  experiment_id    Int?
  description      String
  classification   String?
  status           String    @default("not started")
  priority         String    @default("medium")
  due_date         DateTime? @db.Date
  vikunja_task_id  Int?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  Experiment  FarmExperiment? @relation(fields: [experiment_id], references: [id], onDelete: SetNull)
  Assignees   TaskAssignee[]
  UploadLinks TaskUploadLink[]
  CvatTasks   CvatTask[]

  @@map("Tasks")
  @@schema("pgntarg2udzj1f3")
}

model TaskAssignee {
  task_id Int
  user_id String

  Task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  User User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([task_id, user_id])
  @@map("Task_Assignees")
  @@schema("pgntarg2udzj1f3")
}

model TaskUploadLink {
  task_id      Int
  upload_id    Int
  upload_table String

  Task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@id([task_id, upload_id, upload_table])
  @@map("Task_Upload_Links")
  @@schema("pgntarg2udzj1f3")
}

model TaskTemplate {
  id             Int      @id @default(autoincrement())
  description    String
  classification String?
  priority       String   @default("medium")
  test_id        Int?
  drone_id       Int?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  Test  Test?  @relation(fields: [test_id],  references: [id], onDelete: Cascade)
  Drone Drone? @relation(fields: [drone_id], references: [id], onDelete: Cascade)

  @@map("Task_Templates")
  @@schema("pgntarg2udzj1f3")
}
