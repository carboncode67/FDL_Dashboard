# FDL Dashboard — Environment Template
# ====================================
# Copy this file to ".env.local" and fill in real values. Never commit ".env.local".
#   cp .env.local.example .env.local
#
# Generate a NextAuth secret:
#   openssl rand -base64 32

# --- Database (PostgreSQL) ---
# When running the app inside docker-compose, the host is the "db" service.
# For local "npm run dev" against the containerized DB, use localhost:5433.
DATABASE_URL=postgresql://nocodb:password@localhost:5433/nocodb

# --- NextAuth ---
NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# --- Uploaded file storage ---
# Directory where mobile/lab uploads are written. Defaults to ./upload-data.
DATA_DIR=./upload-data

# --- Optional ---
# URL encoded in farmer QR codes. Defaults to NEXTAUTH_URL. Set when the
# container's external URL/port differs from NEXTAUTH_URL.
FARMER_SERVER_URL=

# Base URL of the OFEDashBot webhook service. Required for the WhatsApp admin
# "send message" feature (POST /api/whatsapp/send forwards to OFEDashBot).
OFEDASHBOT_URL=http://localhost:8001

# Resend credentials — only needed for scheduled email activity reports.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
