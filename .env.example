# Copy to .env and fill in values before running docker compose

# URL this server is reachable at — used for NextAuth callbacks and QR code payloads
NEXTAUTH_URL=http://YOUR_SERVER_IP:3000

# Random secret for NextAuth JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me

# Only needed if the mobile app reaches the server on a different port than 3000
# FARMER_SERVER_URL=http://YOUR_SERVER_IP:3300

# Base URL of the OFEDashBot webhook service (holds the Twilio credentials).
# Required for the WhatsApp admin "send message" feature (POST /api/whatsapp/send).
# OFEDASHBOT_URL=http://YOUR_BOT_HOST:PORT

# Needed only for scheduled email activity reports (Resend).
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=reports@yourdomain.com

# CVAT annotation integration (optional — tasks are saved locally if CVAT vars are not set)
# CVAT_URL=http://your-cvat-host:8080
# CVAT_USERNAME=admin
# CVAT_PASSWORD=your-cvat-password
# CVAT_WEBHOOK_SECRET=random-secret-for-webhook-verification
# NEXT_PUBLIC_CVAT_URL=http://your-cvat-host:8080
