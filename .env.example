# Copy to .env and fill in values before running docker compose

# URL this server is reachable at — used for NextAuth callbacks and QR code payloads
NEXTAUTH_URL=http://YOUR_SERVER_IP:3000

# Random secret for NextAuth JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me

# Only needed if the mobile app reaches the server on a different port than 3000
# FARMER_SERVER_URL=http://YOUR_SERVER_IP:3300
